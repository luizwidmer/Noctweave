{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "types": ["bun"],
    "verbatimModuleSyntax": true
  },
  "include": ["desktop/**/*.ts", "electrobun.config.ts"],
  "exclude": ["artifacts", "build", "node_modules"]
}
